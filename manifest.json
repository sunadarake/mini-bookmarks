{
  "manifest_version": 3,
  "name": "mini bookmarks",
  "version": "2.0.0",
  "description": "Small, but excellent in searchability, another bookmark.",
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": "assets/img/icon_48.png"
  },
  "icons": {
    "128": "assets/img/icon_128.png",
    "48": "assets/img/icon_48.png",
    "16": "assets/img/icon_16.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs"
  ]
}
